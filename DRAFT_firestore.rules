rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // User Validation Blueprint
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'purchasedBooks', 'createdAt', 'updatedAt']) 
        && data.keys().size() == 4
        && data.email is string && data.email.size() <= 200 && data.email == request.auth.token.email
        && data.purchasedBooks is list && data.purchasedBooks.size() <= 50
        && (data.purchasedBooks.size() == 0 || data.purchasedBooks[0] is string)
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    // For updates, createdAt cannot change, and updatedAt must be request.time
    function isValidUserUpdate(data) {
      return data.email is string && data.email.size() <= 200 && data.email == request.auth.token.email
        && data.purchasedBooks is list && data.purchasedBooks.size() <= 50
        && (data.purchasedBooks.size() == 0 || data.purchasedBooks[0] is string)
        && data.createdAt == existing().createdAt
        && data.updatedAt == request.time;
    }

    // 4. Tiered Identity Logic & Relational boundaries
    match /users/{userId} {
      // Users can only read their own data
      allow get: if isVerified() && isValidId(userId) && request.auth.uid == userId;
      
      // Users cannot list other users
      allow list: if false;

      // Create: user can create their own profile
      allow create: if isVerified() 
        && isValidId(userId) 
        && request.auth.uid == userId
        && isValidUser(incoming());

      // Update: user can theoretically update their profile, BUT
      // we strictly forbid modifying purchasedBooks from the client to prevent theft.
      // Modifying purchasedBooks must happen from a secure backend (Admin SDK bypasses rules).
      allow update: if isVerified()
        && isValidId(userId)
        && request.auth.uid == userId
        && isValidUserUpdate(incoming())
        && (
            // User updating general profile fields (none currently beyond system ones)
            incoming().diff(existing()).affectedKeys().hasOnly(['updatedAt'])
        );
      
      allow delete: if false;
    }
  }
}
