rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isVerified() {
      return isSignedIn();
    }
    function isAdmin() {
      return request.auth != null && request.auth.token != null && (
        request.auth.token.email == 'rafaelvidetta@gmail.com' ||
        request.auth.token.email == 'rafaelvidetta32@gmail.com' ||
        request.auth.token.email == 'marc.zbrun@gmail.com'
      );
    }

    // User Validation Blueprint
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'purchasedBooks', 'createdAt', 'updatedAt']) 
        && data.keys().hasAny(['bookProgress', 'bookmarks']) == false || true // allow missing initially
        && data.email is string && data.email.size() <= 200 && data.email == request.auth.token.email
        && data.purchasedBooks is list && data.purchasedBooks.size() <= 50
        && (data.purchasedBooks.size() == 0 || data.purchasedBooks[0] is string)
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    // For updates, createdAt cannot change, and updatedAt must be request.time
    function isValidUserUpdate(data) {
      return data.email is string && data.email.size() <= 200
        && data.purchasedBooks is list && data.purchasedBooks.size() <= 50
        && (data.purchasedBooks.size() == 0 || data.purchasedBooks[0] is string)
        && data.createdAt == existing().createdAt
        && (existing().keys().hasAll(['bookProgress']) == false || data.bookProgress is map)
        && (existing().keys().hasAll(['bookmarks']) == false || data.bookmarks is map)
        && (data.keys().hasAll(['lastLoginAt']) == false || data.lastLoginAt == request.time)
        && (data.keys().hasAll(['loginCount']) == false || data.loginCount is number);
    }

    // Purchase Intent Validation Blueprint
    function isValidPurchaseIntent(data) {
      return data.keys().hasAll(['userId', 'email', 'bookId', 'status', 'createdAt'])
        && data.keys().size() == 5
        && data.userId == request.auth.uid
        && data.email == request.auth.token.email
        && data.bookId is string && data.bookId.size() <= 100
        && data.status is string && data.status == 'pending'
        && data.createdAt == request.time;
    }

    match /purchaseIntents/{intentId} {
      allow create: if isVerified() && isValidId(intentId) && isValidPurchaseIntent(incoming());
      allow read: if isAdmin();
      allow update: if isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status']);
    }

    // 4. Tiered Identity Logic & Relational boundaries
    match /users/{userId}/sessions/{sessionId} {
      allow read: if isAdmin() || (isVerified() && request.auth.uid == userId);
      allow create: if isVerified() && request.auth.uid == userId 
        && incoming().keys().hasAll(['startedAt', 'updatedAt'])
        && incoming().startedAt == request.time;
      allow update: if isVerified() && request.auth.uid == userId
        && incoming().diff(existing()).affectedKeys().hasOnly(['endedAt', 'durationMinutes', 'updatedAt'])
        && incoming().updatedAt == request.time;
    }

    match /users/{userId} {
      allow get: if isAdmin() || (isVerified() && request.auth.uid == userId);
      allow list: if isAdmin();

      // Create: user can create their own profile
      allow create: if isVerified() 
        && request.auth.uid == userId
        && isValidUser(incoming());

      allow update: if isVerified()
        && (
          (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['purchasedBooks', 'updatedAt'])) ||
          (
            request.auth.uid == userId
            && isValidUserUpdate(incoming())
            && (
                incoming().diff(existing()).affectedKeys().hasOnly(['updatedAt']) ||
                incoming().diff(existing()).affectedKeys().hasOnly(['bookProgress', 'updatedAt']) ||
                incoming().diff(existing()).affectedKeys().hasOnly(['bookmarks', 'updatedAt']) ||
                incoming().diff(existing()).affectedKeys().hasOnly(['bookProgress', 'bookmarks', 'updatedAt']) ||
                incoming().diff(existing()).affectedKeys().hasOnly(['lastLoginAt', 'loginCount', 'updatedAt'])
            )
          )
        );
      
      allow delete: if false;
    }
  }
}
