# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="AIzaSyAYbp3d_dlp-L1JgV_1r4ahvx7el-bPNDI"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# 1. MERCADO PAGO
# Ingresa a https://www.mercadopago.com/developers/panel
# Ve a tus credenciales de Producción y copia el "Access Token"
MP_ACCESS_TOKEN=APP_USR-123456789-xxxxxxxx-yyyyyy

# 2. FIREBASE ADMIN (Para manejar la base de datos desde el Servidor de forma inquebrantable)
# Ingresa a tu Google Cloud Console o Firebase Console, ve a Cuentas de Servicio y genera una nueva clave privada.
FIREBASE_PROJECT_ID=gen-lang-client-xxxxxxxx
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@gen-lang-client-xxxxxxxx.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE... \n-----END PRIVATE KEY-----\n"

# 3. GOOGLE ANALYTICS
# Start tracking page views over your app by configuring your GA 4 here.
# Enter your Measurement ID here. e.g "G-XXXXXXXXXX"
VITE_GA_MEASUREMENT_ID=
